# Local SQLite development
DATABASE_URL="file:./dev.db"

# Vercel/production must use hosted Postgres instead:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Required in production. Use a long random string.
AUTH_SECRET="replace-with-a-long-random-secret"

# Public URL used when rendering share links/QR URLs outside the browser.
NEXT_PUBLIC_APP_URL="http://127.0.0.1:3127"

# Optional server-only equivalent if you do not want to expose a public env name.
APP_BASE_URL="http://127.0.0.1:3127"

# Comma-separated emails that should have MVP admin access.
ADMIN_EMAILS="demo@giftly.local"
